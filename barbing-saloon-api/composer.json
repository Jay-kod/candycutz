{
  "name": "candycutz/barbing-saloon-api",
  "type": "project",
  "description": "Barbing Saloon API",
  "require": {
    "php": "^8.2",
    "laravel/framework": "^11.0",
    "laravel/sanctum": "^4.0",
    "spatie/laravel-permission": "^6.0",
    "firebase/php-jwt": "^7.1"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ]
  },
  "config": {
    "audit": {
      "block-insecure": false,
      "ignore": [
        "PKSA-mdq4-51ck-6kdq",
        "PKSA-8qx3-n5y5-vvnd",
        "PKSA-q46n-4fdk-zjr4",
        "PKSA-qzrn-rnz3-85w1",
        "PKSA-w7xr-vk7n-rstm"
      ]
    }
  }
}
